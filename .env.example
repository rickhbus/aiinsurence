# Public Supabase config. These values are safe for browser use and must match
# the Supabase project that has the migrations in ./supabase/migrations applied.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Older Supabase projects may call this publishable key. Leave blank unless used.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only AI provider config. Never prefix these keys with NEXT_PUBLIC_.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-server-key
# Optional: use Vercel AI Gateway for DeepSeek instead of a direct key.
# Vercel OIDC is injected on Vercel and by `vercel env pull`; do not commit it.
AI_GATEWAY_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
AI_MODEL=

# Optional model overrides.
DEEPSEEK_MODEL=deepseek-v4-flash
GROQ_MODEL=
OPENAI_MODEL=

# Optional privacy-safe product analytics routing key.
NEXT_PUBLIC_ANALYTICS_KEY=

# Optional shared rate-limit store for production. Keep these server-only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_REST_URL=
REDIS_REST_TOKEN=
PRODUCTION_API_RATE_LIMIT_ENABLED=
PRODUCTION_API_RATE_LIMIT_WINDOW_SECONDS=60
PRODUCTION_API_RATE_LIMIT_PER_WINDOW=300
PRODUCTION_WRITE_API_RATE_LIMIT_PER_WINDOW=120
PRODUCTION_AI_API_RATE_LIMIT_PER_WINDOW=60

# Production monitoring and alert routing. Keep webhook URLs server-only.
MONITORING_ALERTS_ENABLED=false
MONITORING_ALERT_WEBHOOK_URL=
MONITORING_BASE_URL=
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
VERCEL_LOG_DRAIN_CONFIGURED=false

# Rotation evidence only. Do not put secret values here.
SECRETS_ROTATED_AT=
SECRETS_ROTATION_NEXT_DUE_AT=

# Optional app environment flag. Use production only after env and RLS are ready.
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# App URLs for auth redirects, email links, and deployment runbooks.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
VERCEL_URL=

# Server-only Supabase service role. Leave blank unless a future server-only
# maintenance job explicitly needs it. Never expose this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe payments. Keep STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, and price IDs
# server-only. The publishable key is safe for browser use, but checkout still
# goes through server routes.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_CARE=
STRIPE_PRICE_FAMILY=
