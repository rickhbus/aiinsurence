# Public Supabase config. These values are safe for browser use and must match
# the Supabase project that has the migrations in ./supabase/migrations applied.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Older Supabase projects may call this publishable key. Leave blank unless used.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only AI provider config. Never prefix these keys with NEXT_PUBLIC_.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-server-key
GROQ_API_KEY=
OPENAI_API_KEY=
AI_MODEL=

# Optional model overrides.
DEEPSEEK_MODEL=
GROQ_MODEL=
OPENAI_MODEL=

# Optional privacy-safe product analytics routing key.
NEXT_PUBLIC_ANALYTICS_KEY=

# Optional app environment flag. Use production only after env and RLS are ready.
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development
